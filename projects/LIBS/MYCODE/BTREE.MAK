
clean:
	-DEL UNITS\NUMKEYS.*
	-DEL UNITS\BTBASE.*
	-DEL UNITS\BTISBASE.*
	-DEL UNITS\FILER.*
	-DEL UNITS\ISAMTOOL.*

build:
	CD SOURCE\BTREE

	-BPC -CD NUMKEYS.PAS
	-BPC -CP NUMKEYS.PAS
	-BPC -CD BTBASE.PAS
	-BPC -CP BTBASE.PAS
	-BPC -CD BTISBASE.PAS
	-BPC -CP BTISBASE.PAS
	-BPC -CD FILER.PAS
	-BPC -CP FILER.PAS
	-BPC -CD ISAMTOOL.PAS
	-BPC -CP ISAMTOOL.PAS

	CD ..\..


