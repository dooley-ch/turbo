
clean:
	-DEL UNITS\JDSTRING.*
	-DEL UNITS\JDMONEY.*
	-DEL UNITS\JDUTILS.*
	-DEL UNITS\JDDATES.*

build:
	CD SOURCE\CORE

	-BPC -CD JDSTRING.PAS
	-BPC -CP JDSTRING.PAS
	-BPC -CD JDMONEY.PAS
	-BPC -CP JDMONEY.PAS
	-BPC -CD JDUTILS.PAS
	-BPC -CP JDUTILS.PAS
	-BPC -CD JDDATES.PAS
	-BPC -CP JDDATES.PAS

	CD ..\..


